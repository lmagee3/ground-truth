# Ground Truth — Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# REQUIRED: None! Core sources (GDELT, World Bank, CIA Factbook) need no keys.
# =============================================================================

# =============================================================================
# OPTIONAL: API keys for enhanced data sources
# =============================================================================

# ACLED — Conflict data (free account at acleddata.com)
# ACLED_API_KEY=
# ACLED_EMAIL=

# NARA — National Archives (free key at catalog.archives.gov)
# NARA_API_KEY=

# Congress.gov — Congressional Research Service (free at api.congress.gov)
# CONGRESS_API_KEY=

# GeoNames — Geographic data (free at geonames.org)
# GEONAMES_USERNAME=

# =============================================================================
# AI SYNTHESIS
# =============================================================================

# Claude API (for production context synthesis)
# ANTHROPIC_API_KEY=

# Ollama (for local development — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://localhost:5432/groundtruth
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
LOG_LEVEL=info
