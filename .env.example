# Ground Truth — Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# REQUIRED: None! Core sources (GDELT, World Bank, CIA Factbook) need no keys.
# =============================================================================

# =============================================================================
# OPTIONAL: API keys for enhanced data sources
# =============================================================================

# ACLED — Conflict data (free account at acleddata.com)
# Uses OAuth 2.0: token auto-fetched from username/password
# ACLED_USERNAME=your_email@domain.com
# ACLED_PASSWORD=your_password

# NARA — National Archives (free key at catalog.archives.gov)
# NARA_API_KEY=

# Congress.gov — Congressional Research Service (free at api.congress.gov)
# CONGRESS_API_KEY=

# GeoNames — Geographic data (free at geonames.org)
# GEONAMES_USERNAME=

# =============================================================================
# AI SYNTHESIS
# =============================================================================

# Synthesis provider: "ollama" (free, local) or "anthropic" (paid tiers)
SYNTHESIS_PROVIDER=ollama

# Ollama (for local development + free tier — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120.0

# Claude API (for Pro/Enterprise/Federal tiers only)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://localhost:5432/groundtruth
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# API SERVER
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
LOG_LEVEL=info
